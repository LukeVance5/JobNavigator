{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-2.5-pro",
  "plugin": ["opencode-gemini-auth@latest"],
  "permission": {
    "read": "allow",
    "edit": "ask",
    "bash": "ask"
  },
  "provider": {
    "google": {
      "options": {
        "maxTokens": 65535
      }
    }
  }
}